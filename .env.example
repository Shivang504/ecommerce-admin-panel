# MongoDB (same database the storefront and other apps use)
MONGODB_URI=mongodb://127.0.0.1:27017/ecommerce

# JWT — use the same secret for Admin and Vendor apps if they authenticate against the same database
JWT_SECRET=change-me-to-a-long-random-string

# Canonical URL for this Admin Panel (used in metadata / sitemap)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: forward /api/* browser calls to another origin (e.g. standalone API). Leave unset when this app serves its own /api routes.
# NEXT_PUBLIC_API_BASE_URL=
